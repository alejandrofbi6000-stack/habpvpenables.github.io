<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Catálogo Completo de Enables HABPVP</title>
  <meta name="description" content="Catálogo oficial completo de Enables HABPVP, con buscador, filtros, portada visual y tabla lista para imprimir o exportar." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#04081c;
      --bg-2:#07112d;
      --panel:rgba(10,20,45,.78);
      --panel-2:rgba(14,24,52,.92);
      --line:rgba(57,135,255,.35);
      --line-soft:rgba(112,179,255,.18);
      --text:#eef4ff;
      --muted:#b8c5e8;
      --blue:#1ea0ff;
      --blue-2:#52c6ff;
      --cyan:#72e7ff;
      --orange:#ff9a3d;
      --danger:#ff5869;
      --ok:#71f2b2;
      --dark:#091126;
      --shadow:0 22px 70px rgba(0,0,0,.4);
      --radius:28px;
      --radius-sm:18px;
      --max:1400px;
      --table-header:#60dbe7;
      --table-body:#d5eef0;
      --table-border:#2f3b3d;
    }

    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      color:var(--text);
      font-family:"Outfit", sans-serif;
      background:
        radial-gradient(circle at 0% 45%, rgba(30,160,255,.30), transparent 18%),
        radial-gradient(circle at 100% 38%, rgba(255,154,61,.26), transparent 16%),
        radial-gradient(circle at 50% 0%, rgba(25,71,165,.15), transparent 24%),
        linear-gradient(180deg, #020617 0%, #050b1e 25%, #07112b 60%, #08142d 100%);
      min-height:100vh;
      overflow-x:hidden;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      opacity:.14;
      background-image:
        radial-gradient(circle, rgba(255,255,255,.9) 0 1.5px, transparent 1.6px),
        radial-gradient(circle, rgba(255,255,255,.8) 0 1px, transparent 1.2px);
      background-size:160px 160px, 240px 240px;
      background-position:0 0, 40px 60px;
    }

    body::after{
      content:"";
      position:fixed;
      left:0; right:0; bottom:-4vh;
      height:28vh;
      pointer-events:none;
      opacity:.2;
      background:
        linear-gradient(transparent, rgba(27,105,214,.18)),
        repeating-linear-gradient(90deg, rgba(46,147,255,.28) 0 2px, transparent 2px 76px),
        repeating-linear-gradient(0deg, rgba(46,147,255,.18) 0 2px, transparent 2px 76px);
      transform:perspective(700px) rotateX(72deg);
      transform-origin:bottom;
    }

    .container{
      width:min(calc(100% - 32px), var(--max));
      margin-inline:auto;
    }

    .reveal{
      opacity:0;
      transform:translateY(22px);
      animation:rise .8s ease forwards;
    }
    @keyframes rise{
      to{opacity:1;transform:none}
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:60;
      backdrop-filter:blur(18px);
      background:linear-gradient(180deg, rgba(3,7,19,.9), rgba(3,7,19,.58));
      border-bottom:1px solid rgba(255,255,255,.06);
    }

    .topbar-inner{
      min-height:78px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
    }

    .brand{
      display:flex;
      align-items:center;
      gap:14px;
      color:var(--text);
      text-decoration:none;
    }

    .brand-pill{
      padding:10px 18px;
      border-radius:999px;
      font-weight:900;
      letter-spacing:.04em;
      color:#fff8ed;
      background:linear-gradient(135deg, #08b2ff, #1e7eff);
      border:1px solid rgba(255,255,255,.16);
      box-shadow:0 10px 28px rgba(25,124,255,.3);
    }

    .brand-copy strong{
      display:block;
      font-family:"Space Grotesk", sans-serif;
      font-size:1rem;
      letter-spacing:.03em;
    }

    .brand-copy span{
      color:var(--muted);
      font-size:.86rem;
    }

    .actions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }

    .button{
      appearance:none;
      border:none;
      cursor:pointer;
      text-decoration:none;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:46px;
      padding:0 18px;
      border-radius:999px;
      font:inherit;
      font-weight:800;
      transition:.25s ease;
    }

    .button-primary{
      color:#041321;
      background:linear-gradient(135deg, var(--cyan), var(--blue));
      box-shadow:0 14px 30px rgba(36,163,255,.24);
    }

    .button-primary:hover{transform:translateY(-2px) scale(1.02)}
    .button-primary:active{transform:scale(.98)}

    .button-ghost{
      color:var(--text);
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
    }

    .button-ghost:hover{background:rgba(255,255,255,.08);transform:translateY(-2px)}

    header.hero{
      padding:34px 0 20px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.25fr .75fr;
      gap:26px;
      align-items:stretch;
    }

    .hero-copy{
      position:relative;
      overflow:hidden;
      border-radius:32px;
      padding:34px clamp(20px, 4vw, 42px);
      background:
        linear-gradient(180deg, rgba(7,15,36,.9), rgba(7,14,31,.74)),
        linear-gradient(135deg, rgba(36,163,255,.08), transparent 48%);
      border:1px solid rgba(98,168,255,.16);
      box-shadow:var(--shadow);
    }

    .hero-copy::before{
      content:"";
      position:absolute;
      inset:auto auto -80px -80px;
      width:220px;
      height:220px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(30,160,255,.28), transparent 65%);
      filter:blur(10px);
    }

    .eyebrow{
      display:flex;
      align-items:center;
      gap:16px;
      margin:0 0 18px;
      color:var(--orange);
      text-transform:uppercase;
      letter-spacing:.08em;
      font-size:1rem;
    }

    .eyebrow::after{
      content:"";
      flex:1;
      height:1px;
      background:linear-gradient(90deg, var(--orange), transparent);
    }

    h1{
      margin:0;
      font-family:"Space Grotesk", sans-serif;
      font-size:clamp(2.8rem, 7vw, 5.6rem);
      line-height:.94;
      letter-spacing:-.06em;
      text-transform:uppercase;
      max-width:11ch;
    }

    .accent{color:var(--blue)}

    .hero-sub{
      margin:22px 0 26px;
      max-width:760px;
      font-size:clamp(1rem, 1.8vw, 1.42rem);
      line-height:1.34;
      color:var(--muted);
    }

    .chips{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
    }

    .chip{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:10px 16px;
      border-radius:999px;
      font-weight:800;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:inset 0 1px 0 rgba(255,255,255,.07);
    }

    .chip i{
      width:10px;
      height:10px;
      border-radius:50%;
      display:inline-block;
      background:currentColor;
      box-shadow:0 0 18px currentColor;
    }

    .chip.orange{color:var(--orange)}
    .chip.blue{color:var(--blue)}
    .chip.white{color:#dfe8ff}

    .hero-side{
      position:relative;
      border-radius:30px;
      padding:18px;
      background:linear-gradient(180deg, rgba(12,20,44,.82), rgba(12,20,44,.7));
      border:1px solid rgba(102,170,255,.2);
      box-shadow:var(--shadow);
      overflow:hidden;
      min-height:100%;
    }

    .hero-side::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 25% 22%, rgba(30,160,255,.2), transparent 17%),
        radial-gradient(circle at 70% 68%, rgba(30,160,255,.2), transparent 18%);
      pointer-events:none;
    }

    .mini-grid{
      position:relative;
      z-index:1;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
      height:100%;
    }

    .mini-card{
      position:relative;
      min-height:140px;
      border-radius:22px;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      display:grid;
      place-items:center;
      padding:14px;
      overflow:hidden;
      transition:.25s ease;
    }

    .mini-card:hover{
      transform:translateY(-4px);
      border-color:rgba(94,200,255,.32);
      box-shadow:0 16px 28px rgba(0,0,0,.24);
    }

    .mini-card .label{
      position:absolute;
      left:12px;
      bottom:12px;
      font-weight:900;
      font-size:.84rem;
      text-transform:uppercase;
      letter-spacing:.03em;
    }

    .avatar{
      width:72px;
      height:102px;
      position:relative;
      filter:drop-shadow(0 0 20px rgba(36,163,255,.25));
    }

    .avatar .head,
    .avatar .body,
    .avatar .arm,
    .avatar .leg{
      position:absolute;
      background:#c8ccd1;
      border:2px solid #6e7788;
    }

    .avatar .head{
      width:30px;height:30px;border-radius:50%;
      left:21px;top:0;
    }
    .avatar .body{
      width:22px;height:38px;border-radius:10px;
      left:25px;top:28px;
    }
    .avatar .arm.left{width:9px;height:30px;border-radius:10px;left:17px;top:32px;transform:rotate(12deg)}
    .avatar .arm.right{width:9px;height:30px;border-radius:10px;right:17px;top:32px;transform:rotate(-10deg)}
    .avatar .leg.left{width:10px;height:32px;border-radius:10px;left:24px;bottom:0;transform:rotate(4deg)}
    .avatar .leg.right{width:10px;height:32px;border-radius:10px;right:24px;bottom:0;transform:rotate(-4deg)}

    .fx-ring::after,
    .fx-board::after,
    .fx-fire::after,
    .fx-glow::after,
    .fx-badge::after{
      content:"";
      position:absolute;
      left:50%;
      transform:translateX(-50%);
      pointer-events:none;
    }

    .fx-ring::after{
      width:58px;height:58px;border-radius:50%;
      top:8px;
      border:4px solid rgba(30,160,255,.95);
      box-shadow:0 0 22px rgba(30,160,255,.5), inset 0 0 12px rgba(30,160,255,.25);
    }

    .fx-board::after{
      bottom:4px;
      width:58px;height:10px;border-radius:12px;
      background:linear-gradient(90deg, #62d0ff, #2f89ff);
      box-shadow:0 0 18px rgba(47,137,255,.55);
    }

    .fx-fire::after{
      top:22px;
      width:18px;height:28px;
      background:radial-gradient(circle at 50% 80%, #ffe16e 0 24%, #ff9c33 36%, #ff531f 58%, transparent 68%);
    }

    .fx-glow::after{
      bottom:2px;
      width:52px;height:16px;border-radius:50%;
      background:radial-gradient(circle, rgba(30,160,255,.9), rgba(30,160,255,.28) 45%, transparent 70%);
    }

    .fx-badge::after{
      top:-4px;
      width:26px;height:26px;border-radius:50%;
      background:radial-gradient(circle, #ffd36a 20%, #c88f1e 65%, transparent 66%);
    }

    .toolbar{
      padding:16px 0;
    }

    .toolbar-shell{
      display:grid;
      grid-template-columns:1.2fr .8fr;
      gap:16px;
      padding:16px;
      border-radius:24px;
      background:var(--panel);
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter:blur(14px);
      box-shadow:var(--shadow);
    }

    .search-group,
    .filter-group{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      align-items:center;
    }

    .field,
    .select{
      flex:1 1 230px;
      min-height:52px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.04);
      color:var(--text);
      padding:0 16px;
      font:inherit;
      outline:none;
      transition:.2s ease;
    }

    .field::placeholder{color:#9cb0d7}
    .field:focus,
    .select:focus{
      border-color:rgba(114,231,255,.45);
      box-shadow:0 0 0 4px rgba(114,231,255,.12);
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:14px;
      margin:10px 0 22px;
    }

    .stat{
      border-radius:22px;
      padding:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.07);
      box-shadow:var(--shadow);
    }

    .stat .k{
      display:block;
      font-family:"Space Grotesk", sans-serif;
      font-size:clamp(1.6rem, 3vw, 2.4rem);
      line-height:1;
      margin-bottom:6px;
    }

    .stat .t{
      color:var(--muted);
      font-size:.95rem;
    }

    .section-title{
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:12px;
      margin:18px 0 14px;
    }

    .section-title h2{
      margin:0;
      font-family:"Space Grotesk", sans-serif;
      font-size:clamp(1.6rem, 3vw, 2.5rem);
      letter-spacing:-.04em;
      text-transform:uppercase;
    }

    .section-title p{
      margin:0;
      color:var(--muted);
      max-width:820px;
    }

    .table-wrap{
      border-radius:28px;
      overflow:hidden;
      box-shadow:var(--shadow);
      border:1px solid rgba(94,200,255,.16);
      background:rgba(255,255,255,.02);
    }

    .table-scroll{
      overflow:auto;
      max-height:75vh;
      background:var(--table-body);
    }

    table{
      width:100%;
      border-collapse:collapse;
      min-width:1100px;
    }

    thead th{
      position:sticky;
      top:0;
      z-index:3;
      background:var(--table-header);
      color:#09131f;
      text-transform:uppercase;
      font-weight:900;
      font-size:.96rem;
      padding:14px 14px;
      border:2px solid var(--table-border);
      text-align:left;
    }

    tbody td{
      border:2px solid var(--table-border);
      padding:10px 12px;
      vertical-align:middle;
      color:#121212;
      background:var(--table-body);
    }

    tbody tr:hover td{
      background:#cce8ea;
    }

    td.image-col{width:92px}
    td.num{
      width:110px;
      font-family:"Space Grotesk", sans-serif;
      font-weight:700;
      font-size:1.08rem;
    }

    td.name{
      min-width:320px;
      font-weight:700;
    }

    td.cat{min-width:180px}
    td.keys{min-width:320px;color:#2d3a40}
    td.state{
      width:150px;
      font-weight:900;
      text-transform:uppercase;
      letter-spacing:.03em;
    }

    .state-ok{color:#057a3e}
    .state-off{color:#d82038}

    .thumb{
      width:56px;
      height:56px;
      border-radius:12px;
      position:relative;
      background:
        linear-gradient(135deg, rgba(255,255,255,.5), rgba(255,255,255,.18)),
        repeating-linear-gradient(135deg, rgba(0,0,0,.05) 0 2px, transparent 2px 10px);
      border:1px solid rgba(0,0,0,.15);
      overflow:hidden;
      margin:auto;
    }

    .thumb .mini-avatar{
      position:absolute;
      left:50%;
      top:50%;
      transform:translate(-50%,-50%) scale(.52);
      width:72px;
      height:102px;
    }

    .thumb .badge-x{
      position:absolute;
      inset:0;
      display:grid;
      place-items:center;
      color:var(--danger);
      font-family:"Space Grotesk", sans-serif;
      font-size:2rem;
      font-weight:900;
    }

    .empty{
      display:none;
      text-align:center;
      padding:20px;
      color:#1d2b33;
      background:var(--table-body);
      border-top:2px solid var(--table-border);
    }

    .footer{
      padding:28px 0 48px;
    }

    .footer-box{
      border-radius:20px;
      padding:20px 22px;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.08);
    }

    .note{
      margin:0;
      color:var(--muted);
      line-height:1.55;
    }

    @media (max-width: 1080px){
      .hero-grid,
      .toolbar-shell{
        grid-template-columns:1fr;
      }
      .stats{
        grid-template-columns:repeat(2,1fr);
      }
    }

    @media (max-width: 700px){
      .topbar-inner{
        min-height:auto;
        padding:12px 0;
        flex-direction:column;
        align-items:flex-start;
      }
      .stats{
        grid-template-columns:1fr;
      }
      .hero-side{
        min-height:420px;
      }
    }

    @media print{
      body{
        background:#fff;
        color:#000;
      }
      body::before, body::after, .topbar, .toolbar, .hero-side, .actions{
        display:none !important;
      }
      .hero-copy, .stat, .footer-box{
        box-shadow:none;
        background:#fff;
        border:1px solid #ccc;
        color:#000;
      }
      .hero-sub, .section-title p, .note, .stat .t{
        color:#333 !important;
      }
      .table-scroll{
        overflow:visible;
        max-height:none;
      }
      .table-wrap{
        box-shadow:none;
        border:none;
      }
    }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="container topbar-inner">
      <a class="brand" href="#inicio" aria-label="Ir al inicio">
        <span class="brand-pill">HABPVP</span>
        <span class="brand-copy">
          <strong>Catálogo Completo de Enables</strong>
          <span>Versión HTML inspirada en la portada de referencia</span>
        </span>
      </a>
      <div class="actions">
        <button class="button button-ghost" id="resetFilters">Limpiar filtros</button>
        <button class="button button-primary" onclick="window.print()">Imprimir / Guardar PDF</button>
      </div>
    </div>
  </div>

  <header class="hero" id="inicio">
    <div class="container hero-grid">
      <section class="hero-copy reveal">
        <p class="eyebrow">Catálogo oficial</p>
        <h1>Catálogo completo de <span class="accent">Enables</span> HABPVP</h1>
        <p class="hero-sub">
          Guía visual y descriptiva de todos los accesorios, vehículos y efectos especiales disponibles
          para personalizar los avatares dentro de la comunidad de HABPVP.
        </p>
        <div class="chips">
          <span class="chip orange"><i></i>400+ enables activos</span>
          <span class="chip blue"><i></i>Categorías visuales</span>
          <span class="chip white"><i></i>HABPVP community</span>
        </div>
      </section>

      <aside class="hero-side reveal" aria-label="Resumen visual de categorías">
        <div class="mini-grid">
          <div class="mini-card">
            <div class="avatar fx-ring">
              <span class="head"></span><span class="body"></span><span class="arm left"></span><span class="arm right"></span><span class="leg left"></span><span class="leg right"></span>
            </div>
            <span class="label">Disfraces</span>
          </div>
          <div class="mini-card">
            <div class="avatar fx-board">
              <span class="head"></span><span class="body"></span><span class="arm left"></span><span class="arm right"></span><span class="leg left"></span><span class="leg right"></span>
            </div>
            <span class="label">Transportes</span>
          </div>
          <div class="mini-card">
            <div class="avatar fx-fire">
              <span class="head"></span><span class="body"></span><span class="arm left"></span><span class="arm right"></span><span class="leg left"></span><span class="leg right"></span>
            </div>
            <span class="label">Efectos</span>
          </div>
          <div class="mini-card">
            <div class="avatar fx-glow">
              <span class="head"></span><span class="body"></span><span class="arm left"></span><span class="arm right"></span><span class="leg left"></span><span class="leg right"></span>
            </div>
            <span class="label">Accesorios</span>
          </div>
          <div class="mini-card">
            <div class="avatar fx-badge">
              <span class="head"></span><span class="body"></span><span class="arm left"></span><span class="arm right"></span><span class="leg left"></span><span class="leg right"></span>
            </div>
            <span class="label">Medallas</span>
          </div>
          <div class="mini-card" style="align-items:end;">
            <div style="text-align:left;width:100%;">
              <div style="font-family:'Space Grotesk',sans-serif;font-size:2.2rem;font-weight:700;color:var(--blue-2);line-height:1;">Catálogo</div>
              <div style="margin-top:8px;font-weight:900;text-transform:uppercase;">Completo</div>
              <div style="margin-top:6px;color:var(--muted);font-size:.95rem;">Todos los enables listados del documento.</div>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </header>

  <main class="container">
    <section class="toolbar reveal">
      <div class="toolbar-shell">
        <div class="search-group">
          <input id="searchInput" class="field" type="search" placeholder="Buscar por número, nombre o palabra clave..." aria-label="Buscar enable">
          <select id="statusFilter" class="select" aria-label="Filtrar por estado">
            <option value="all">Todos los estados</option>
            <option value="disponible">Disponibles</option>
            <option value="no disponible">No disponibles</option>
          </select>
        </div>
        <div class="filter-group">
          <select id="categoryFilter" class="select" aria-label="Filtrar por categoría">
            <option value="all">Todas las categorías</option>
          </select>
        </div>
      </div>
    </section>

    <section class="stats reveal">
      <article class="stat">
        <span class="k" id="statTotal">0</span>
        <span class="t">Registros totales</span>
