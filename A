      {numero:"2000",nombre:"Fantasma rojo",keywords:"sábana, espectro, disfraz",estado:"Disponible"},
      {numero:"2001",nombre:"Atado / Amarrado",keywords:"cuerdas, secuestrado",estado:"Disponible"}
    ];

    function categorize(name, keywords, estado){
      const text = (name + " " + keywords).toLowerCase();
      if (estado.toLowerCase() === "no disponible") return "No disponible";
      if (text.includes("medalla") || text.includes("vip dorado")) return "Medallas";
      if (text.includes("coche") || text.includes("tabla voladora") || text.includes("avioneta") || text.includes("hoverboard") || text.includes("skate") || text.includes("patinete") || text.includes("scooter") || text.includes("jeep") || text.includes("tanque") || text.includes("montura") || text.includes("snowboard") || text.includes("alfombra")) return "Transportes";
      if (text.includes("máscara") || text.includes("cabeza") || text.includes("disfraz") || text.includes("fantasma") || text.includes("among us") || text.includes("vikingo") || text.includes("hombre lobo") || text.includes("momia") || text.includes("calabaza") || text.includes("payaso")) return "Disfraces";
      if (text.includes("emoji") || text.includes("llamas") || text.includes("foco") || text.includes("brillos") || text.includes("lluvia") || text.includes("corazones") || text.includes("ondas") || text.includes("aliento") || text.includes("dragón") || text.includes("aureola") || text.includes("pajaritos") || text.includes("luciérnagas") || text.includes("mariposas")) return "Efectos";
      if (text.includes("pistola") || text.includes("fusil") || text.includes("subfusil") || text.includes("rifle") || text.includes("escudo") || text.includes("espada") || text.includes("sable") || text.includes("varita") || text.includes("bastón") || text.includes("micrófono") || text.includes("gafas") || text.includes("teléfono") || text.includes("botella") || text.includes("llave") || text.includes("bate")) return "Accesorios";
      if (text.includes("animación") || text.includes("saltar") || text.includes("girar") || text.includes("shake") || text.includes("caminando") || text.includes("subiendo escaleras")) return "Animaciones";
      return "Otros";
    }

    function thumbFx(category){
      switch(category){
        case "Transportes": return "fx-board";
        case "Disfraces": return "fx-ring";
        case "Efectos": return "fx-glow";
        case "Medallas": return "fx-badge";
        case "Accesorios": return "fx-fire";
        case "Animaciones": return "fx-glow";
        default: return "fx-glow";
      }
    }

    const bodyEl = document.getElementById("catalogBody");
    const searchInput = document.getElementById("searchInput");
    const statusFilter = document.getElementById("statusFilter");
    const categoryFilter = document.getElementById("categoryFilter");
    const resetFilters = document.getElementById("resetFilters");
    const emptyState = document.getElementById("emptyState");

    const statTotal = document.getElementById("statTotal");
    const statAvailable = document.getElementById("statAvailable");
    const statUnavailable = document.getElementById("statUnavailable");
    const statVisible = document.getElementById("statVisible");

    const normalizedCatalog = catalog.map(item => ({
      ...item,
      categoria: categorize(item.nombre, item.keywords, item.estado)
    }));

    function createThumb(item){
      const thumb = document.getElementById("thumbTemplate").content.firstElementChild.cloneNode(true);
      if(item.estado.toLowerCase() === "no disponible"){
        thumb.innerHTML = '<div class="badge-x">X</div>';
        return thumb;
      }
      const avatar = thumb.querySelector(".mini-avatar");
      avatar.classList.add(thumbFx(item.categoria));
      return thumb;
    }

    function renderTable(data){
      bodyEl.innerHTML = "";
      data.forEach(item => {
        const tr = document.createElement("tr");

        const tdImage = document.createElement("td");
        tdImage.className = "image-col";
        tdImage.appendChild(createThumb(item));

        const tdNum = document.createElement("td");
        tdNum.className = "num";
        tdNum.textContent = item.numero;

        const tdName = document.createElement("td");
        tdName.className = "name";
        tdName.textContent = item.nombre;

        const tdCat = document.createElement("td");
        tdCat.className = "cat";
        tdCat.textContent = item.categoria;

        const tdKeys = document.createElement("td");
        tdKeys.className = "keys";
        tdKeys.textContent = item.keywords || "—";

        const tdState = document.createElement("td");
        tdState.className = "state " + (item.estado.toLowerCase() === "no disponible" ? "state-off" : "state-ok");
        tdState.textContent = item.estado;

        tr.append(tdImage, tdNum, tdName, tdCat, tdKeys, tdState);
        bodyEl.appendChild(tr);
      });

      emptyState.style.display = data.length ? "none" : "block";
      statVisible.textContent = data.length;
    }

    function populateCategories(){
      const categories = [...new Set(normalizedCatalog.map(i => i.categoria))];
      categories.sort((a,b)=>a.localeCompare(b));
      categoryFilter.innerHTML = '<option value="all">Todas las categorías</option>';
      categories.forEach(cat => {
        const option = document.createElement("option");
        option.value = cat.toLowerCase();
        option.textContent = cat;
        categoryFilter.appendChild(option);
      });
    }

    function updateStats(){
      statTotal.textContent = normalizedCatalog.length;
      statAvailable.textContent = normalizedCatalog.filter(i => i.estado.toLowerCase() !== "no disponible").length;
      statUnavailable.textContent = normalizedCatalog.filter(i => i.estado.toLowerCase() === "no disponible").length;
    }

    function applyFilters(){
      const q = searchInput.value.trim().toLowerCase();
      const status = statusFilter.value;
      const category = categoryFilter.value;

      const filtered = normalizedCatalog.filter(item => {
        const haystack = [item.numero, item.nombre, item.keywords, item.estado, item.categoria].join(" ").toLowerCase();
        const matchSearch = !q || haystack.includes(q);
        const matchStatus =
          status === "all" ||
          (status === "disponible" && item.estado.toLowerCase() !== "no disponible") ||
          (status === "no disponible" && item.estado.toLowerCase() === "no disponible");
        const matchCategory =
          category === "all" || item.categoria.toLowerCase() === category;

        return matchSearch && matchStatus && matchCategory;
      });

      renderTable(filtered);
    }

    searchInput.addEventListener("input", applyFilters);
    statusFilter.addEventListener("change", applyFilters);
    categoryFilter.addEventListener("change", applyFilters);

    resetFilters.addEventListener("click", () => {
      searchInput.value = "";
      statusFilter.value = "all";
      categoryFilter.value = "all";
      applyFilters();
    });

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.style.animationPlayState = "running";
          observer.unobserve(entry.target);
        }
      });
    }, {threshold:.14});

    document.querySelectorAll(".reveal").forEach((el, i) => {
      el.style.animationDelay = `${i * 0.08}s`;
      el.style.animationPlayState = "paused";
      observer.observe(el);
    });

    populateCategories();
    updateStats();
    renderTable(normalizedCatalog);
  </script>
</body>
